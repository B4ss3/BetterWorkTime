<Window x:Class="BetterWorkTime.App.EditEntryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Entry"
        Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <DockPanel Margin="16">

        <!-- Buttons pinned to bottom -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Save" Width="80" Height="30" IsDefault="True"
                    Click="Save_Click" Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="80" Height="30" IsCancel="True"/>
        </StackPanel>

        <!-- Error text -->
        <TextBlock x:Name="ErrorText" DockPanel.Dock="Bottom"
                   Foreground="Red" FontSize="12" Margin="0,6,0,0"
                   TextWrapping="Wrap" Visibility="Collapsed"/>

        <!-- Form -->
        <StackPanel>

            <!-- Time range -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Start (HH:mm)" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox x:Name="StartBox" FontSize="14"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="–" VerticalAlignment="Bottom"
                           HorizontalAlignment="Center" Margin="0,0,0,4" FontSize="16"/>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="End (HH:mm)" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox x:Name="EndBox" FontSize="14"/>
                </StackPanel>
            </Grid>

            <!-- Project -->
            <TextBlock Text="Project" FontSize="12" Margin="0,0,0,4"/>
            <ComboBox x:Name="ProjectCombo" DisplayMemberPath="Name"
                      Margin="0,0,0,10"
                      SelectionChanged="ProjectCombo_SelectionChanged"/>

            <!-- Task -->
            <TextBlock Text="Task" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="TaskBox" Margin="0,0,0,10"
                     GotFocus="TaskBox_GotFocus"
                     LostFocus="TaskBox_LostFocus"/>

            <!-- Note -->
            <TextBlock Text="Note" FontSize="12" Margin="0,0,0,4"/>
            <TextBox x:Name="NoteBox" Height="54"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>

        </StackPanel>
    </DockPanel>
</Window>
