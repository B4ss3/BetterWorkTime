<Window x:Class="BetterWorkTime.App.HydrationPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hydration Reminder"
        Width="320" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        Topmost="True">

    <StackPanel Margin="24">
        <TextBlock Text="💧" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
        <TextBlock Text="Time to drink some water!"
                   FontSize="18" FontWeight="SemiBold"
                   HorizontalAlignment="Center" TextWrapping="Wrap"
                   TextAlignment="Center" Margin="0,0,0,8"/>
        <TextBlock Text="Take a short break and hydrate."
                   FontSize="13" HorizontalAlignment="Center"
                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                   Margin="0,0,0,20"/>
        <Button Content="Got it!" Width="120" Height="34"
                HorizontalAlignment="Center"
                IsDefault="True" Click="GotIt_Click"/>
    </StackPanel>

</Window>
