<Window x:Class="BetterWorkTime.App.MainWindow"
        WindowStartupLocation="CenterScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BetterWorkTime.App"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="16" VerticalAlignment="Top">
            <TextBlock Text="BetterWorkTime" FontSize="22" FontWeight="SemiBold" />
            <TextBlock x:Name="StatusText" Margin="0,12,0,0" FontSize="14" />
            <TextBlock x:Name="ElapsedText" Margin="0,6,0,0" FontSize="18" FontWeight="SemiBold" />

            <Button x:Name="StartStopButton"
            Margin="0,16,0,0"
            Width="160"
            Height="38"
            Click="StartStopButton_Click" />
        </StackPanel>

    </Grid>
</Window>
