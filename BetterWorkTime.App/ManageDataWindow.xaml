<Window x:Class="BetterWorkTime.App.ManageDataWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Projects &amp; Tags"
        Width="540" Height="500"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <TabControl>

            <!-- ── Projects ── -->
            <TabItem Header="Projects">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid Grid.Row="0" x:Name="ProjectsGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              Margin="0,0,0,8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name"  Binding="{Binding Name}"  Width="*"/>
                            <DataGridTextColumn Header="Color" Binding="{Binding Color}" Width="80"/>
                            <DataGridTemplateColumn Header="Status" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ArchivedLabel}" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding ToggleLabel}"
                                                Tag="{Binding Id}"
                                                Click="ToggleProjectArchive_Click"
                                                Padding="4,2" Margin="2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <TextBox x:Name="NewProjectName" Width="180" Margin="0,0,8,0"/>
                        <ComboBox x:Name="NewProjectColor" Width="110" Margin="0,0,8,0"
                                  DisplayMemberPath="Label"/>
                        <Button Content="Add Project" Click="AddProject_Click" Padding="8,4"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ── Tags ── -->
            <TabItem Header="Tags">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid Grid.Row="0" x:Name="TagsGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              Margin="0,0,0,8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name"  Binding="{Binding Name}"  Width="*"/>
                            <DataGridTextColumn Header="Color" Binding="{Binding Color}" Width="80"/>
                            <DataGridTemplateColumn Header="Status" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ArchivedLabel}" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding ToggleLabel}"
                                                Tag="{Binding Id}"
                                                Click="ToggleTagArchive_Click"
                                                Padding="4,2" Margin="2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal">
                        <TextBox x:Name="NewTagName" Width="180" Margin="0,0,8,0"/>
                        <ComboBox x:Name="NewTagColor" Width="110" Margin="0,0,8,0"
                                  DisplayMemberPath="Label"/>
                        <Button Content="Add Tag" Click="AddTag_Click" Padding="8,4"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
