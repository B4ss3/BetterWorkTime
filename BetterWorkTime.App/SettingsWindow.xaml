<Window x:Class="BetterWorkTime.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <DockPanel Margin="16">

        <!-- Save / Close buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Save" Width="80" Height="30" IsDefault="True"
                    Click="Save_Click" Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="80" Height="30" IsCancel="True"/>
        </StackPanel>

        <TabControl>

            <!-- ── General ───────────────────────────────────────── -->
            <TabItem Header="General">
                <StackPanel Margin="12">

                    <CheckBox x:Name="StartMinimizedBox"
                              Content="Start minimized to tray"
                              FontSize="13" Margin="0,0,0,14"/>

                    <Separator Margin="0,0,0,14"/>

                    <TextBlock Text="Global hotkeys (Ctrl+Alt+…)"
                               FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <CheckBox x:Name="HotkeysEnabledBox"
                              Content="Enable global hotkeys"
                              FontSize="13" Margin="0,0,0,8"/>
                    <TextBlock FontSize="11" Foreground="Gray" Margin="0,0,0,4">
                        <Run Text="S"/>
                        <Run Text=" — Start / Stop"/>
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="Gray" Margin="0,0,0,4">
                        <Run Text="T"/>
                        <Run Text=" — Switch Task"/>
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="Gray" Margin="0,0,0,4">
                        <Run Text="O"/>
                        <Run Text=" — Open main window"/>
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="Gray" Margin="0,0,0,4">
                        <Run Text="N"/>
                        <Run Text=" — Add Note"/>
                    </TextBlock>

                    <Separator Margin="0,14,0,14"/>

                    <Button Content="Open data folder"
                            HorizontalAlignment="Left" Padding="10,5"
                            Click="OpenDataFolder_Click"/>

                </StackPanel>
            </TabItem>

            <!-- ── Tracking ─────────────────────────────────────── -->
            <TabItem Header="Tracking">
                <StackPanel Margin="12">

                    <TextBlock Text="Idle threshold" FontSize="13" Margin="0,0,0,6"/>
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock Text="minutes" DockPanel.Dock="Right"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <TextBox x:Name="IdleThresholdBox" Width="60"
                                 HorizontalAlignment="Left" FontSize="13"/>
                    </DockPanel>
                    <TextBlock Text="How long the computer must be idle before a prompt appears."
                               FontSize="11" Foreground="Gray" TextWrapping="Wrap"
                               Margin="0,4,0,0"/>

                </StackPanel>
            </TabItem>

            <!-- ── Hydration ─────────────────────────────────────── -->
            <TabItem Header="Hydration">
                <StackPanel Margin="12">

                    <CheckBox x:Name="HydrationEnabledBox"
                              Content="Enable hydration reminders"
                              FontSize="13" Margin="0,0,0,14"
                              Checked="HydrationEnabled_Changed"
                              Unchecked="HydrationEnabled_Changed"/>

                    <TextBlock Text="Reminder interval" FontSize="13" Margin="0,0,0,6"/>
                    <DockPanel Margin="0,0,0,16">
                        <TextBlock Text="minutes" DockPanel.Dock="Right"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <TextBox x:Name="HydrationIntervalBox" Width="60"
                                 HorizontalAlignment="Left" FontSize="13"/>
                    </DockPanel>

                    <TextBlock Text="Sound" FontSize="13" Margin="0,0,0,6"/>
                    <DockPanel Margin="0,0,0,6">
                        <Button Content="▶ Preview" DockPanel.Dock="Right"
                                Padding="8,4" Margin="8,0,0,0"
                                Click="PreviewSound_Click"/>
                        <ComboBox x:Name="SoundCombo"
                                  DisplayMemberPath="Label"
                                  SelectionChanged="SoundCombo_SelectionChanged"/>
                    </DockPanel>
                    <Button Content="Browse for custom sound…"
                            HorizontalAlignment="Left" Padding="8,4"
                            Margin="0,0,0,4"
                            Click="BrowseSound_Click"/>
                    <TextBlock x:Name="CustomSoundLabel"
                               FontSize="11" Foreground="Gray"
                               TextTrimming="CharacterEllipsis"
                               Visibility="Collapsed"/>

                    <Separator Margin="0,12,0,12"/>

                    <CheckBox x:Name="RespectFocusAssistBox" FontSize="12">
                        <TextBlock Text="Respect Focus Assist (delay reminder while active)"
                                   TextWrapping="Wrap"/>
                    </CheckBox>

                </StackPanel>
            </TabItem>

            <!-- ── Export ────────────────────────────────────────── -->
            <TabItem Header="Export">
                <StackPanel Margin="12">

                    <CheckBox x:Name="OpenFolderAfterExportBox"
                              Content="Open folder after export"
                              FontSize="13" Margin="0,0,0,14"/>

                    <TextBlock Text="Last export folder" FontSize="13" Margin="0,0,0,6"/>
                    <DockPanel Margin="0,0,0,4">
                        <Button Content="Clear" DockPanel.Dock="Right"
                                Padding="8,4" Margin="8,0,0,0"
                                Click="ClearExportFolder_Click"/>
                        <TextBlock x:Name="LastExportFolderText"
                                   FontSize="12" Foreground="Gray"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </DockPanel>

                </StackPanel>
            </TabItem>

            <!-- ── About ─────────────────────────────────────────── -->
            <TabItem Header="About">
                <StackPanel Margin="12">

                    <TextBlock Text="BetterWorkTime" FontSize="16" FontWeight="SemiBold"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="VersionText" FontSize="13" Foreground="Gray"
                               Margin="0,0,0,16"/>

                    <Button Content="Open logs folder"
                            HorizontalAlignment="Left" Padding="10,5" Margin="0,0,0,8"
                            Click="OpenLogsFolder_Click"/>

                    <Button Content="Open data folder"
                            HorizontalAlignment="Left" Padding="10,5"
                            Click="OpenDataFolder_Click"/>

                </StackPanel>
            </TabItem>

        </TabControl>

    </DockPanel>
</Window>
