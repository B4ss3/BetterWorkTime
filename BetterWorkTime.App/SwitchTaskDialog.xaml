<Window x:Class="BetterWorkTime.App.SwitchTaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Switch Task"
        Width="340" Height="240"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <DockPanel Margin="16">

        <!-- Buttons pinned to bottom -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Switch" Width="80" Height="32" IsDefault="True"
                    Click="Switch_Click" Margin="0,0,8,0"/>
            <Button Content="Cancel" Width="80" Height="32" IsCancel="True"
                    Click="Cancel_Click"/>
        </StackPanel>

        <!-- Content fills remaining space top-down -->
        <StackPanel>
            <TextBlock Text="Project" Margin="0,0,0,4"/>
            <ComboBox x:Name="ProjectCombo"
                      DisplayMemberPath="Name"
                      Margin="0,0,0,12"
                      SelectionChanged="ProjectCombo_SelectionChanged"/>

            <TextBlock Text="Task" Margin="0,0,0,4"/>
            <TextBox x:Name="TaskNameBox"
                     GotFocus="TaskNameBox_GotFocus"
                     LostFocus="TaskNameBox_LostFocus"/>
        </StackPanel>

    </DockPanel>
</Window>
